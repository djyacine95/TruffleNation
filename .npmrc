# Allow peer dependency conflicts (equivalent to pnpm's strict-peer-dependencies=false)
# Needed because esbuild-plugin-pino declares a tighter esbuild peer range than what we use
legacy-peer-deps=true

# Tell pnpm to prefer local workspace packages even without the workspace: protocol.
# This lets package.json files use "*" for cross-workspace deps, which is also
# valid npm workspace syntax — so the same package.json files work with both
# pnpm (local dev) and npm (Render deployment).
link-workspace-packages=true
