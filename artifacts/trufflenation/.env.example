# TruffleNation frontend (Vite) — copy to `.env` or `.env.local` in this folder,
# OR use a single `.env` at the monorepo root (TruffleNation/.env); Vite merges both.

# Required for sign-in, cart, orders, and seller tools (get a dev key from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: Clerk proxy for custom domains in production
# VITE_CLERK_PROXY_URL=https://api.example.com/api/__clerk

# Optional: Express API base URL (defaults to same-origin `/api` in dev via Vite proxy)
# VITE_API_URL=http://localhost:8080
