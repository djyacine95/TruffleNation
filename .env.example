# ─────────────────────────────────────────────────────────────
# TruffleNation — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Neon PostgreSQL connection string (or any PostgreSQL URL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Server ───────────────────────────────────────────────────
# Port the Express API server listens on
PORT=8080

# Set to "production" when deploying; "development" for local dev
NODE_ENV=development

# ── Clerk Authentication ──────────────────────────────────────
# Get these from your Clerk dashboard → API Keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Secret key: server only — never prefix with VITE_. Used by `artifacts/api-server` (loaded from this root `.env`).
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publishable key: required in the browser for sign-in (Vite reads from this root `.env` or `artifacts/trufflenation/.env`).
# Leave empty to browse marketing pages locally without sign-in; cart/account still need a key.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shown on the /contact page mailto (optional).
# VITE_SUPPORT_EMAIL=support@yourdomain.com

# Clerk proxy URL — set this to your production domain + the proxy path.
# Enables Clerk to work on custom domains without a CNAME record.
# Example: https://api.yourdomain.com/api/__clerk
# Leave blank in development.
VITE_CLERK_PROXY_URL=

# ── Optional ─────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Absolute path to the built frontend assets, used when Express serves the SPA.
# Defaults to ../../trufflenation/dist/public relative to the API server dist/.
# FRONTEND_DIST=/absolute/path/to/artifacts/trufflenation/dist/public

# After db:push, seed demo truffle listings for the shop (requires DATABASE_URL):
# npm run db:seed
