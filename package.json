{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "build:prod": "npm run build --workspace=@workspace/trufflenation && npm run build --workspace=@workspace/api-server",
    "start": "NODE_ENV=production npm run start --workspace=@workspace/api-server",
    "dev:api": "npm run dev --workspace=@workspace/api-server",
    "dev:web": "npm run dev --workspace=@workspace/trufflenation",
    "db:push": "npm run push --workspace=@workspace/db",
    "db:seed": "npm run seed-db --workspace=@workspace/scripts",
    "codegen": "npm run codegen --workspace=@workspace/api-spec"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
